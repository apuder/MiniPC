

LIBS = /usr/lib/gcc/riscv64-unknown-elf/13.2.0/rv32i/ilp32/libgcc.a


OBJCOPY = riscv64-unknown-elf-objcopy
OBJDUMP = riscv64-unknown-elf-objdump

# Options for the RISC cross compiler
COMMONFLAGS = -march=rv32i2p0 -mabi=ilp32
CC = riscv64-unknown-elf-gcc
CFLAGS = -mno-save-restore $(COMMONFLAGS) -nostartfiles -nostdlib -static -O1 -I../include

AS = riscv64-unknown-elf-as
ASFLAGS = $(COMMONFLAGS)

AR = riscv64-unknown-elf-ar

# Options for the host C-compiler
CC_HOST = gcc
CC_HOST_OPT = -I.

# Options for the host C++-compiler
CPP_HOST = g++

LD_HOST = gcc
LD_HOST_OPT = 

STRIP=strip

MAKEDEPEND = makedepend -f-
